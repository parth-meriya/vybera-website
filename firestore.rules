rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// VYBERA — Firestore Security Rules (Production Hardened)
// ═══════════════════════════════════════════════════════════════
//
// Security model:
//  - No public read/write to sensitive collections
//  - Authenticated users can read/write only their own data
//  - Admin operations require Firebase custom claim { admin: true }
//    (custom claims are set server-side only via Firebase Admin SDK)
//  - Firestore role field is a secondary check — not trusted for
//    high-privilege operations without custom claim validation
//
// Deploy: firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────

    // Check if the user is authenticated
    function isAuthed() {
      return request.auth != null;
    }

    // Check if the requesting user owns the resource (by uid field)
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Check for Firebase custom claim (set server-side via Admin SDK)
    function hasAdminClaim() {
      return isAuthed() && request.auth.token.admin == true;
    }

    // ── Users Collection ────────────────────────────────────────
    // Users can read/write their own profile.
    // Admins can read all user profiles (for AdminUsers page).
    // NO ONE (not even admin) can modify the 'role' field from client.
    match /users/{uid} {
      allow read: if isOwner(uid) || hasAdminClaim();

      // Allow user to create their own profile at signup
      allow create: if isOwner(uid)
        && request.resource.data.role == 'user'  // Prevent self-promotion to admin
        && request.resource.data.uid == uid;

      // Allow user to update their own profile (but NOT change role)
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role  // Role cannot be changed
        && request.resource.data.uid == resource.data.uid;   // UID cannot be changed

      // Admins can update any user (including role changes via Admin SDK)
      allow update: if hasAdminClaim();

      // No deletion of user documents from client
      allow delete: if false;
    }

    // ── Products Collection ─────────────────────────────────────
    // Everyone can read products (store catalog is public).
    // Only admins can create, update, or delete products.
    match /products/{productId} {
      allow read: if true;  // Public catalog read
      allow create, update, delete: if hasAdminClaim();
    }

    // ── Orders Collection ───────────────────────────────────────
    // Users can read and create their own orders.
    // Users can update only return requests on their own orders.
    // Admins can read all orders and update any order.
    match /orders/{orderId} {
      // User can read their own order
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow read: if hasAdminClaim();

      // User can create an order with their own uid
      allow create: if isAuthed()
        && request.resource.data.userId == request.auth.uid;

      // User can update only the returnRequest field on their own order
      allow update: if isAuthed()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['returnRequest']);

      // Admin can update any order (status, tracking, payment)
      allow update: if hasAdminClaim();

      allow delete: if false;  // Never delete orders
    }

    // ── Coupons Collection ──────────────────────────────────────
    // Authenticated users can validate/read coupons.
    // Only admins can create, update, or delete coupons.
    match /coupons/{couponId} {
      allow read: if isAuthed();  // Required for frontend coupon validation
      allow create, update, delete: if hasAdminClaim();
    }

    // ── Settings Collection ─────────────────────────────────────
    // Everyone can read settings (banner config, customize prices).
    // Only admins can write settings.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasAdminClaim();
    }

    // ── Custom Orders Collection ────────────────────────────────
    // Users can create and read their own custom orders.
    // Admins can read all and update any.
    match /customOrders/{orderId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow read: if hasAdminClaim();
      allow create: if isAuthed()
        && request.resource.data.userId == request.auth.uid;
      allow update: if hasAdminClaim();
      allow delete: if false;
    }

    // ── Reviews Collection ──────────────────────────────────────
    // Everyone can read reviews.
    // Authenticated users can create reviews (one review per product enforcement
    // should be done in app logic or Cloud Functions).
    // Admins can delete/moderate reviews.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthed()
        && resource.data.userId == request.auth.uid;
      allow delete: if hasAdminClaim();
    }

    // ── Contact / Support Messages ──────────────────────────────
    // Anyone can submit a contact message (no auth required for reach).
    // Only admins can read messages.
    match /messages/{msgId} {
      allow create: if true;  // Public contact form
      allow read, update, delete: if hasAdminClaim();
    }

    // ── Sales / Campaigns Collection ───────────────────────────
    // Everyone can read active sales.
    // Only admins can manage sales.
    match /sales/{saleId} {
      allow read: if true;
      allow write: if hasAdminClaim();
    }

    // ── Default: Deny All ───────────────────────────────────────
    // Any collection not explicitly listed above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
